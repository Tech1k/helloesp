{
  "ci": {
    "collect": {
      "url": [
        "https://helloesp.com/",
        "https://helloesp.com/guestbook",
        "https://helloesp.com/history",
        "https://helloesp.com/console",
        "https://helloesp.com/about",
        "https://helloesp.com/snake",
        "https://helloesp.com/chronicle"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
